{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "TSA Builder Node",
  "type": "object",
  "description": "Input and output contract for the FACIS TSA builder node aligned to the TSA SRS.",
  "properties": {
    "instanceName": { "type": "string", "minLength": 1 },
    "domainAddress": { "type": "string", "minLength": 1 },
    "policyRepoUrl": { "type": "string", "minLength": 1 },
    "policyRepoFolder": { "type": "string" },
    "eidasCompliance": { "type": "boolean", "default": false },
    "trustKeyContent": { "type": "string" },
    "trustChainContent": { "type": "string" },
    "kubeconfigContent": { "type": "string", "minLength": 1 },
    "privateKeyContent": { "type": "string", "minLength": 1 },
    "certificateContent": { "type": "string", "minLength": 1 }
  },
  "required": [
    "instanceName",
    "domainAddress",
    "policyRepoUrl",
    "kubeconfigContent",
    "privateKeyContent",
    "certificateContent"
  ],
  "outputContract": {
    "type": "object",
    "required": ["tsaUrl", "keyId", "policyStatus", "status"],
    "properties": {
      "tsaUrl": { "type": "string", "format": "uri" },
      "keyId": { "type": "string" },
      "policyStatus": { "type": "string" },
      "status": { "type": "string" }
    }
  },
  "uiSections": [
    "Instance Info",
    "Cluster & Domain",
    "Trust Configuration"
  ]
}
